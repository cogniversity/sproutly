# PostgreSQL 17+ (e.g. Neon). Prisma reads DATABASE_URL.
# Cursor Cloud often injects PG_CONNECTION_STRING — mirror it locally:
# DATABASE_URL="${PG_CONNECTION_STRING}"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Optional: workspace AI fallback when no per-workspace key is set (dev only).
# OPENAI_API_KEY=
